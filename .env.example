# Web UI access
# Set one of these before binding the UI beyond localhost.
ARDA_UI_USERNAME=arda
ARDA_UI_PASSWORD=change-me
# ARDA_UI_TOKEN=change-me

# NPM credentials for syncing
NPM_URL=https://npm.example.internal
NPM_EMAIL=user@example.com
NPM_PASSWORD=change-me

# Integration API keys referenced by data/integrations.yml
PVE_API_TOKEN=PVEAPIToken=user@pam!token-name=change-me

# Optional Proxmox fallback if a node is not configured in data/integrations.yml
PVE_URL=https://proxmox.example.internal:8006

# Service API keys referenced by data/services/*.yml
JELLYFIN_API_KEY=change-me
UNIFI_API_TOKEN=change-me
TRUENAS_API_KEY=change-me
PROWLARR_API_KEY=change-me
ABS_API_KEY=change-me
SONARR_API_KEY=change-me
RADARR_API_KEY=change-me
NZBGET_API_KEY=change-me

# Optional UniFi overrides
UNIFI_URL=https://unifi.example.internal
UNIFI_SITE=default
UNIFI_VERIFY_SSL=false

# Optional Mafl deploy path overrides
MAFL_DEPLOY_MODE=landing
MAFL_OUTPUT_PATH=/mnt/downloads/mafl/config.yml
MAFL_NAS_PATH=/mnt/downloads/mafl/config.yml
MAFL_LIVE_PATH=/docker/mafl/config.yml
MAFL_RESTART_COMMAND=docker restart mafl
